# ============================================================
# Variables de Entorno - Despliegue EC2
# ============================================================
# INSTRUCCIONES:
# 1. Copiar este archivo como .env.ec2:  cp .env.ec2.template .env.ec2
# 2. Reemplazar los valores placeholder con valores reales
# 3. NUNCA commitear .env.ec2 al repositorio
# ============================================================

# Perfil Spring Boot (no modificar)
SPRING_PROFILES_ACTIVE=ec2

# JWT - Token de autenticación
# Generar un secret seguro: openssl rand -base64 48
JWT_SECRET=REEMPLAZAR_CON_SECRET_SEGURO
JWT_EXPIRATION_MS=300000
JWT_MAX_FAILED_ATTEMPTS=3

# Encriptación AES-256
# Clave Base64 de 32 bytes: openssl rand -base64 32
AES_KEY=REEMPLAZAR_CON_CLAVE_AES_BASE64

# AWS DynamoDB
# Endpoint regional (ej: https://dynamodb.us-east-1.amazonaws.com)
DYNAMODB_ENDPOINT=https://dynamodb.us-east-1.amazonaws.com
DYNAMODB_REGION=us-east-1

# Credenciales AWS (usuario IAM con permisos DynamoDB)
# Permisos mínimos requeridos: dynamodb:CreateTable, PutItem, GetItem,
# Query, Scan, DeleteItem, UpdateItem, DescribeTable
DYNAMODB_ACCESS_KEY=REEMPLAZAR_CON_AWS_ACCESS_KEY
DYNAMODB_SECRET_KEY=REEMPLAZAR_CON_AWS_SECRET_KEY
